<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A0A">

    <!-- Camera preview fills screen -->
    <androidx.camera.view.PreviewView
        android:id="@+id/viewFinder"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:scaleType="fillCenter" />

    <!-- Scan overlay (shown during scanning) -->
    <FrameLayout
        android:id="@+id/scanOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#44000000"
        android:visibility="gone">

        <!-- Animated scan line -->
        <View
            android:id="@+id/scanLine"
            android:layout_width="match_parent"
            android:layout_height="3dp"
            android:background="@color/accent_green"
            android:elevation="4dp" />

        <!-- Corner frame indicators -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="32dp">

            <View android:id="@+id/cornerTL"
                android:layout_width="40dp" android:layout_height="40dp"
                android:background="@drawable/corner_tl"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <View android:id="@+id/cornerTR"
                android:layout_width="40dp" android:layout_height="40dp"
                android:background="@drawable/corner_tr"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <View android:id="@+id/cornerBL"
                android:layout_width="40dp" android:layout_height="40dp"
                android:background="@drawable/corner_bl"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />

            <View android:id="@+id/cornerBR"
                android:layout_width="40dp" android:layout_height="40dp"
                android:background="@drawable/corner_br"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />
        </androidx.constraintlayout.widget.ConstraintLayout>
    </FrameLayout>

    <!-- Top bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:paddingTop="48dp"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="⚡ ElectroScan"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold"
            android:fontFamily="monospace" />

        <Button
            android:id="@+id/btnHelp"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:text="?"
            android:textSize="16sp"
            android:padding="0dp"
            style="@style/IconButton" />

        <Button
            android:id="@+id/btnFlash"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:text="⚡"
            android:textSize="16sp"
            android:padding="0dp"
            android:layout_marginStart="8dp"
            style="@style/IconButton" />
    </LinearLayout>

    <!-- Loading indicator -->
    <LinearLayout
        android:id="@+id/loadingGroup"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone"
        android:padding="24dp"
        android:background="@drawable/loading_bg">

        <ProgressBar
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:indeterminateTint="@color/accent_green" />

        <TextView
            android:id="@+id/tvLoadingText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Analysing components..."
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:layout_marginTop="12dp"
            android:fontFamily="monospace" />
    </LinearLayout>

    <!-- Bottom controls -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:padding="24dp"
        android:background="@drawable/bottom_gradient">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:text="Point camera at your electronics components"
            android:textColor="#CCFFFFFF"
            android:textSize="13sp"
            android:layout_marginBottom="16dp" />

        <Button
            android:id="@+id/btnScan"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:text="SCAN"
            android:textSize="18sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:fontFamily="monospace"
            style="@style/ScanButton" />
    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
